# Alpaca API credentials — paper trading by default
# Copy this file to .env and fill in your real keys
# .env is gitignored and will NEVER be committed

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# Set to False only when you are ready to trade with real money
ALPACA_PAPER_TRADE=True

# Self-heal heartbeat (optional) — healthchecks.io ping URL. The watcher
# pings this on every successful scan; healthchecks.io alerts you if the
# pings stop (GitHub outage, crash). Leave unset to disable. Format:
# https://hc-ping.com/<your-check-uuid>
HEALTHCHECK_PING_URL=

# Secrets — never commit
.env
.env.local
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Claude Code runtime — local config + lock files, never share
.claude/

# Watcher build
.pytest_cache/
state/*.json
state/*.jsonl
*.log
old_regime_output.txt
new_regime_output.txt

# Day-trade strategy state files — committed and owned by the
# refresh-day-calendars workflow, not the watcher. Carve these out
# of the broad state/*.json ignore above.
!state/earnings.json
!state/econ_events.json
